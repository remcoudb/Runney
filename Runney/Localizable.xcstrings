    "Running, but as a game. Build your stamina, consistency, and speed, level up, and collect badges along the way.": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hardlopen, maar dan als spel. Bouw je stamina, consistentie en snelheid op, groei in level, en verzamel badges onderweg."
          }
        }
      }
    },
    "What should we call you?": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoe mogen we je noemen?"
          }
