    "Effective weekly volume": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Effectief weekvolume"
          }
        }
      },
      "comment": "Stamina detail row"
    },
    "Stamina shows how much you've been running lately. We look at your average weekly volume over the last 4 weeks, with more recent weeks weighing more heavily — so your score doesn't crash after a single rest week.": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stamina laat zien hoeveel je de laatste tijd hardloopt. We kijken naar je gemiddelde weekvolume over de laatste 4 weken, waarbij recentere weken zwaarder meewegen — zo zakt je score niet meteen keihard na één rustweek."
          }
        }
      },
      "comment": "Stamina description"
    },
    "Build up your weekly kilometers gradually.": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bouw je wekelijkse kilometers geleidelijk op."
          }
        }
      },
      "comment": "Stamina tip"
    },
    "One rest week is fine — your score only drops slowly along with it.": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Eén rustweek is prima — je score daalt maar langzaam mee."
          }
        }
      },
      "comment": "Stamina tip"
    },
    "From 50 km per week you're at the maximum score.": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vanaf 50 km per week zit je op de maximale score."
          }
        }
      },
      "comment": "Stamina tip"
    },
    "Runs this week": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs deze week"
          }
        }
      },
      "comment": "Consistency detail row"
    },
    "1 week": {
      "localizations": {
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "1 week"
          }
        }
      },
      "comment": "Streak duration"
